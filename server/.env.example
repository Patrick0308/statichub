# Database
STATICHUB_DATABASE_URL=sqlite:statichub.db

# Server Configuration
STATICHUB_PORT=3000
STATICHUB_ALLOWED_DOMAINS=localhost,statichub.dev

# Storage
STATICHUB_STORAGE_PATH=~/.statichub/deploys

# OAuth (Google)
STATICHUB_GOOGLE_CLIENT_ID=your_client_id_here
STATICHUB_GOOGLE_CLIENT_SECRET=your_client_secret_here
STATICHUB_GOOGLE_REDIRECT_URL=http://localhost:3000/auth/callback/google

# JWT
STATICHUB_JWT_SECRET=your_jwt_secret_here_use_a_long_random_string
